# Ergane - Git Ignore File

# ---------------------------------------------------------------------------
# Sensitive Data - NEVER COMMIT
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# API Keys (backup patterns)
*.key
*.keys
*.pem
credentials.json

# ---------------------------------------------------------------------------
# Database & Logs
# ---------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
logs/
*.log

# CV Output (contains personal data)
cv_output/
*.docx
*.pdf

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# Web app
web/node_modules/
web/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.swp

# ---------------------------------------------------------------------------
# Test Outputs
# ---------------------------------------------------------------------------
cv_sonnet.md
cv_haiku.md
cv_comparison_stats.txt
test_*.py
!tests/*.py

# ---------------------------------------------------------------------------
# Session Summaries (optional - keep if you want history)
# ---------------------------------------------------------------------------
# SESSION_*.md
# *_session-summary.md
